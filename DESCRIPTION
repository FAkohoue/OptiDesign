Package: OptiDesign
Type: Package
Title: Optimized Experimental Field Design for Plant Breeding
Version: 0.1.0
Authors@R:
    person(
      given   = "Félicien",
      family  = "Akohoue",
      email   = "akohoue.f@gmail.com",
      role    = c("aut", "cre"),
      comment = c(ORCID = "0000-0002-2160-0182")
